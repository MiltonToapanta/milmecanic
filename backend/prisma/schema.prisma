generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                         String              @id @default(uuid()) @db.Uuid
  firstName                  String              @map("first_name") @db.VarChar(100)
  lastName                   String              @map("last_name") @db.VarChar(100)
  email                      String              @unique @db.VarChar(180)
  passwordHash               String              @map("password_hash")
  phone                      String?             @db.VarChar(30)
  isActive                   Boolean             @default(true) @map("is_active")
  roleId                     String              @map("role_id") @db.Uuid
  lastLoginAt                DateTime?           @map("last_login_at") @db.Timestamptz
  createdAt                  DateTime            @default(now()) @map("created_at") @db.Timestamptz
  updatedAt                  DateTime            @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt                  DateTime?           @map("deleted_at") @db.Timestamptz
  createdById                String?             @map("created_by_id") @db.Uuid
  updatedById                String?             @map("updated_by_id") @db.Uuid
  role                       Role                @relation(fields: [roleId], references: [id])
  refreshTokens              RefreshToken[]
  createdUsers               User[]              @relation("UserCreatedBy")
  createdBy                  User?               @relation("UserCreatedBy", fields: [createdById], references: [id])
  updatedUsers               User[]              @relation("UserUpdatedBy")
  updatedBy                  User?               @relation("UserUpdatedBy", fields: [updatedById], references: [id])
  auditLogs                  AuditLog[]
  createdCustomers           Customer[]          @relation("CustomerCreatedBy")
  updatedCustomers           Customer[]          @relation("CustomerUpdatedBy")
  createdVehicles            Vehicle[]           @relation("VehicleCreatedBy")
  updatedVehicles            Vehicle[]           @relation("VehicleUpdatedBy")
  assignedAppointments       Appointment[]       @relation("AppointmentAssignedUser")
  createdAppointments        Appointment[]       @relation("AppointmentCreatedBy")
  updatedAppointments        Appointment[]       @relation("AppointmentUpdatedBy")
  advisorServiceOrders       ServiceOrder[]      @relation("ServiceOrderAssignedAdvisor")
  mechanicServiceOrders      ServiceOrder[]      @relation("ServiceOrderAssignedMechanic")
  createdServiceOrders       ServiceOrder[]      @relation("ServiceOrderCreatedBy")
  updatedServiceOrders       ServiceOrder[]      @relation("ServiceOrderUpdatedBy")
  createdDiagnostics         ServiceDiagnostic[] @relation("ServiceDiagnosticCreatedBy")
  updatedDiagnostics         ServiceDiagnostic[] @relation("ServiceDiagnosticUpdatedBy")
  createdQuotations          Quotation[]         @relation("QuotationCreatedBy")
  updatedQuotations          Quotation[]         @relation("QuotationUpdatedBy")
  createdInventoryCategories InventoryCategory[] @relation("InventoryCategoryCreatedBy")
  updatedInventoryCategories InventoryCategory[] @relation("InventoryCategoryUpdatedBy")
  createdInventoryProducts   InventoryProduct[]  @relation("InventoryProductCreatedBy")
  updatedInventoryProducts   InventoryProduct[]  @relation("InventoryProductUpdatedBy")
  createdWarehouses          Warehouse[]         @relation("WarehouseCreatedBy")
  updatedWarehouses          Warehouse[]         @relation("WarehouseUpdatedBy")
  createdStockMovements      StockMovement[]     @relation("StockMovementCreatedBy")

  @@index([roleId])
  @@index([isActive])
  @@map("users")
}

enum CustomerType {
  PERSON
  COMPANY
}

enum IdentificationType {
  CEDULA
  RUC
  PASSPORT
  OTHER
}

model Customer {
  id                 String             @id @default(uuid()) @db.Uuid
  customerType       CustomerType       @map("customer_type")
  identificationType IdentificationType @map("identification_type")
  identification     String             @db.VarChar(20)
  firstName          String?            @map("first_name") @db.VarChar(100)
  lastName           String?            @map("last_name") @db.VarChar(100)
  businessName       String?            @map("business_name") @db.VarChar(180)
  email              String?            @db.VarChar(180)
  phone              String?            @db.VarChar(20)
  secondaryPhone     String?            @map("secondary_phone") @db.VarChar(20)
  address            String?            @db.VarChar(255)
  city               String?            @db.VarChar(100)
  notes              String?
  isActive           Boolean            @default(true) @map("is_active")
  createdAt          DateTime           @default(now()) @map("created_at") @db.Timestamptz
  updatedAt          DateTime           @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt          DateTime?          @map("deleted_at") @db.Timestamptz
  createdById        String?            @map("created_by_id") @db.Uuid
  updatedById        String?            @map("updated_by_id") @db.Uuid
  createdBy          User?              @relation("CustomerCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy          User?              @relation("CustomerUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  vehicles           Vehicle[]
  appointments       Appointment[]
  serviceOrders      ServiceOrder[]

  @@index([customerType])
  @@index([identificationType])
  @@index([isActive])
  @@index([deletedAt])
  @@map("customers")
}

enum FuelType {
  GASOLINE
  DIESEL
  HYBRID
  ELECTRIC
  GAS
  OTHER
}

enum TransmissionType {
  MANUAL
  AUTOMATIC
  CVT
  OTHER
}

model Vehicle {
  id               String           @id @default(uuid()) @db.Uuid
  customerId       String           @map("customer_id") @db.Uuid
  plate            String           @db.VarChar(10)
  vin              String?          @db.VarChar(30)
  brand            String           @db.VarChar(80)
  model            String           @db.VarChar(80)
  year             Int
  color            String?          @db.VarChar(60)
  engineNumber     String?          @map("engine_number") @db.VarChar(80)
  chassisNumber    String?          @map("chassis_number") @db.VarChar(80)
  fuelType         FuelType         @map("fuel_type")
  transmissionType TransmissionType @map("transmission_type")
  mileage          Int              @default(0)
  notes            String?
  isActive         Boolean          @default(true) @map("is_active")
  createdAt        DateTime         @default(now()) @map("created_at") @db.Timestamptz
  updatedAt        DateTime         @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt        DateTime?        @map("deleted_at") @db.Timestamptz
  createdById      String?          @map("created_by_id") @db.Uuid
  updatedById      String?          @map("updated_by_id") @db.Uuid
  customer         Customer         @relation(fields: [customerId], references: [id])
  createdBy        User?            @relation("VehicleCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy        User?            @relation("VehicleUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  appointments     Appointment[]
  serviceOrders    ServiceOrder[]

  @@index([customerId])
  @@index([brand])
  @@index([fuelType])
  @@index([transmissionType])
  @@index([isActive])
  @@index([deletedAt])
  @@map("vehicles")
}

enum AppointmentStatus {
  SCHEDULED
  CONFIRMED
  IN_PROGRESS
  COMPLETED
  CANCELLED
  NO_SHOW
}

model Appointment {
  id                       String            @id @default(uuid()) @db.Uuid
  customerId               String            @map("customer_id") @db.Uuid
  vehicleId                String            @map("vehicle_id") @db.Uuid
  assignedUserId           String?           @map("assigned_user_id") @db.Uuid
  scheduledAt              DateTime          @map("scheduled_at") @db.Timestamptz
  estimatedDurationMinutes Int               @map("estimated_duration_minutes")
  reason                   String            @db.VarChar(250)
  notes                    String?
  status                   AppointmentStatus @default(SCHEDULED)
  cancellationReason       String?           @map("cancellation_reason") @db.VarChar(250)
  createdAt                DateTime          @default(now()) @map("created_at") @db.Timestamptz
  updatedAt                DateTime          @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt                DateTime?         @map("deleted_at") @db.Timestamptz
  createdById              String?           @map("created_by_id") @db.Uuid
  updatedById              String?           @map("updated_by_id") @db.Uuid
  customer                 Customer          @relation(fields: [customerId], references: [id])
  vehicle                  Vehicle           @relation(fields: [vehicleId], references: [id])
  assignedUser             User?             @relation("AppointmentAssignedUser", fields: [assignedUserId], references: [id], onDelete: SetNull)
  createdBy                User?             @relation("AppointmentCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy                User?             @relation("AppointmentUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  serviceOrders            ServiceOrder[]

  @@index([customerId])
  @@index([vehicleId])
  @@index([assignedUserId])
  @@index([scheduledAt])
  @@index([status])
  @@index([deletedAt])
  @@map("appointments")
}

enum ServiceOrderStatus {
  RECEIVED
  DIAGNOSIS
  WAITING_APPROVAL
  APPROVED
  IN_REPAIR
  QUALITY_CONTROL
  READY_FOR_DELIVERY
  DELIVERED
  CANCELLED
}

enum QuotationStatus {
  DRAFT
  SENT
  APPROVED
  REJECTED
  EXPIRED
  CANCELLED
}

enum QuotationItemType {
  LABOR
  PART
  SUPPLY
  OTHER
}

enum FuelLevel {
  EMPTY
  QUARTER
  HALF
  THREE_QUARTERS
  FULL
}

model ServiceOrder {
  id                    String              @id @default(uuid()) @db.Uuid
  orderNumber           String              @unique @map("order_number") @db.VarChar(30)
  customerId            String              @map("customer_id") @db.Uuid
  vehicleId             String              @map("vehicle_id") @db.Uuid
  appointmentId         String?             @map("appointment_id") @db.Uuid
  assignedAdvisorId     String?             @map("assigned_advisor_id") @db.Uuid
  assignedMechanicId    String?             @map("assigned_mechanic_id") @db.Uuid
  status                ServiceOrderStatus  @default(RECEIVED)
  reportedMileage       Int                 @default(0) @map("reported_mileage")
  fuelLevel             FuelLevel           @map("fuel_level")
  customerRequest       String              @map("customer_request")
  initialDiagnosis      String?             @map("initial_diagnosis")
  internalNotes         String?             @map("internal_notes")
  exteriorCondition     String?             @map("exterior_condition")
  interiorCondition     String?             @map("interior_condition")
  receivedAccessories   String?             @map("received_accessories")
  customerSignatureName String?             @map("customer_signature_name") @db.VarChar(160)
  workshopSignatureName String?             @map("workshop_signature_name") @db.VarChar(160)
  estimatedDeliveryAt   DateTime?           @map("estimated_delivery_at") @db.Timestamptz
  startedAt             DateTime?           @map("started_at") @db.Timestamptz
  completedAt           DateTime?           @map("completed_at") @db.Timestamptz
  deliveredAt           DateTime?           @map("delivered_at") @db.Timestamptz
  cancellationReason    String?             @map("cancellation_reason") @db.VarChar(250)
  isActive              Boolean             @default(true) @map("is_active")
  createdAt             DateTime            @default(now()) @map("created_at") @db.Timestamptz
  updatedAt             DateTime            @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt             DateTime?           @map("deleted_at") @db.Timestamptz
  createdById           String?             @map("created_by_id") @db.Uuid
  updatedById           String?             @map("updated_by_id") @db.Uuid
  customer              Customer            @relation(fields: [customerId], references: [id])
  vehicle               Vehicle             @relation(fields: [vehicleId], references: [id])
  appointment           Appointment?        @relation(fields: [appointmentId], references: [id], onDelete: SetNull)
  assignedAdvisor       User?               @relation("ServiceOrderAssignedAdvisor", fields: [assignedAdvisorId], references: [id], onDelete: SetNull)
  assignedMechanic      User?               @relation("ServiceOrderAssignedMechanic", fields: [assignedMechanicId], references: [id], onDelete: SetNull)
  createdBy             User?               @relation("ServiceOrderCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy             User?               @relation("ServiceOrderUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  photos                ServiceOrderPhoto[]
  diagnostics           ServiceDiagnostic[]
  quotations            Quotation[]

  @@index([customerId])
  @@index([vehicleId])
  @@index([appointmentId])
  @@index([assignedAdvisorId])
  @@index([assignedMechanicId])
  @@index([status])
  @@index([createdAt])
  @@index([deletedAt])
  @@map("service_orders")
}

model ServiceOrderPhoto {
  id             String       @id @default(uuid()) @db.Uuid
  serviceOrderId String       @map("service_order_id") @db.Uuid
  fileName       String       @map("file_name") @db.VarChar(255)
  originalName   String       @map("original_name") @db.VarChar(255)
  mimeType       String       @map("mime_type") @db.VarChar(100)
  size           Int
  url            String
  caption        String?      @db.VarChar(255)
  createdAt      DateTime     @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime     @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt      DateTime?    @map("deleted_at") @db.Timestamptz
  serviceOrder   ServiceOrder @relation(fields: [serviceOrderId], references: [id], onDelete: Cascade)

  @@index([serviceOrderId])
  @@index([deletedAt])
  @@map("service_order_photos")
}

enum DiagnosticItemStatus {
  GOOD
  REGULAR
  BAD
  NOT_CHECKED
}

enum DiagnosticSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum DiagnosticCategory {
  ENGINE
  BRAKES
  SUSPENSION
  STEERING
  TRANSMISSION
  ELECTRICAL
  BATTERY
  TIRES
  COOLING
  EXHAUST
  BODY
  LIGHTS
  FLUIDS
  OTHER
}

model ServiceDiagnostic {
  id                 String                  @id @default(uuid()) @db.Uuid
  serviceOrderId     String                  @map("service_order_id") @db.Uuid
  generalObservation String?                 @map("general_observation")
  recommendation     String?
  completedAt        DateTime?               @map("completed_at") @db.Timestamptz
  createdAt          DateTime                @default(now()) @map("created_at") @db.Timestamptz
  updatedAt          DateTime                @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt          DateTime?               @map("deleted_at") @db.Timestamptz
  createdById        String?                 @map("created_by_id") @db.Uuid
  updatedById        String?                 @map("updated_by_id") @db.Uuid
  serviceOrder       ServiceOrder            @relation(fields: [serviceOrderId], references: [id], onDelete: Cascade)
  createdBy          User?                   @relation("ServiceDiagnosticCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy          User?                   @relation("ServiceDiagnosticUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  items              ServiceDiagnosticItem[]

  @@index([serviceOrderId])
  @@index([completedAt])
  @@index([deletedAt])
  @@map("service_diagnostics")
}

model ServiceDiagnosticItem {
  id           String               @id @default(uuid()) @db.Uuid
  diagnosticId String               @map("diagnostic_id") @db.Uuid
  category     DiagnosticCategory
  itemName     String               @map("item_name") @db.VarChar(120)
  status       DiagnosticItemStatus
  observation  String?
  severity     DiagnosticSeverity?
  createdAt    DateTime             @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime             @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt    DateTime?            @map("deleted_at") @db.Timestamptz
  diagnostic   ServiceDiagnostic    @relation(fields: [diagnosticId], references: [id], onDelete: Cascade)

  @@index([diagnosticId])
  @@index([category])
  @@index([status])
  @@index([severity])
  @@index([deletedAt])
  @@map("service_diagnostic_items")
}

model Quotation {
  id              String          @id @default(uuid()) @db.Uuid
  quotationNumber String          @unique @map("quotation_number") @db.VarChar(30)
  serviceOrderId  String          @map("service_order_id") @db.Uuid
  status          QuotationStatus @default(DRAFT)
  subtotal        Decimal         @db.Decimal(12, 2)
  discount        Decimal         @default(0) @db.Decimal(12, 2)
  tax             Decimal         @default(0) @db.Decimal(12, 2)
  total           Decimal         @db.Decimal(12, 2)
  validUntil      DateTime?       @map("valid_until") @db.Timestamptz
  notes           String?
  approvedAt      DateTime?       @map("approved_at") @db.Timestamptz
  rejectedAt      DateTime?       @map("rejected_at") @db.Timestamptz
  rejectionReason String?         @map("rejection_reason") @db.VarChar(500)
  createdAt       DateTime        @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime        @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt       DateTime?       @map("deleted_at") @db.Timestamptz
  createdById     String?         @map("created_by_id") @db.Uuid
  updatedById     String?         @map("updated_by_id") @db.Uuid
  serviceOrder    ServiceOrder    @relation(fields: [serviceOrderId], references: [id])
  createdBy       User?           @relation("QuotationCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy       User?           @relation("QuotationUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  items           QuotationItem[]

  @@index([serviceOrderId])
  @@index([status])
  @@index([createdAt])
  @@index([deletedAt])
  @@map("quotations")
}

model QuotationItem {
  id          String            @id @default(uuid()) @db.Uuid
  quotationId String            @map("quotation_id") @db.Uuid
  itemType    QuotationItemType @map("item_type")
  description String            @db.VarChar(250)
  quantity    Decimal           @db.Decimal(10, 2)
  unitPrice   Decimal           @map("unit_price") @db.Decimal(12, 2)
  discount    Decimal           @default(0) @db.Decimal(12, 2)
  taxRate     Decimal           @default(0) @map("tax_rate") @db.Decimal(5, 2)
  subtotal    Decimal           @db.Decimal(12, 2)
  tax         Decimal           @default(0) @db.Decimal(12, 2)
  total       Decimal           @db.Decimal(12, 2)
  createdAt   DateTime          @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime          @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt   DateTime?         @map("deleted_at") @db.Timestamptz
  quotation   Quotation         @relation(fields: [quotationId], references: [id], onDelete: Cascade)

  @@index([quotationId])
  @@index([itemType])
  @@index([deletedAt])
  @@map("quotation_items")
}

model QuotationCounter {
  id            String   @id @default(uuid()) @db.Uuid
  prefix        String   @unique @db.VarChar(15)
  currentNumber Int      @default(0) @map("current_number")
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt     DateTime @updatedAt @map("updated_at") @db.Timestamptz

  @@map("quotation_counters")
}

enum InventoryUnit {
  UNIT
  PAIR
  SET
  LITER
  MILLILITER
  GALLON
  KILOGRAM
  GRAM
  METER
  CENTIMETER
  BOX
  PACKAGE
  OTHER
}

enum StockMovementType {
  INITIAL
  PURCHASE_ENTRY
  MANUAL_ENTRY
  TRANSFER_IN
  TRANSFER_OUT
  SERVICE_ORDER_EXIT
  RETURN_ENTRY
  ADJUSTMENT_IN
  ADJUSTMENT_OUT
  DAMAGED_EXIT
}

enum StockReferenceType {
  MANUAL
  PURCHASE
  TRANSFER
  SERVICE_ORDER
  QUOTATION
  RETURN
  ADJUSTMENT
  OTHER
}

model InventoryCategory {
  id          String             @id @default(uuid()) @db.Uuid
  name        String             @db.VarChar(120)
  description String?
  isActive    Boolean            @default(true) @map("is_active")
  createdAt   DateTime           @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime           @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt   DateTime?          @map("deleted_at") @db.Timestamptz
  createdById String?            @map("created_by_id") @db.Uuid
  updatedById String?            @map("updated_by_id") @db.Uuid
  createdBy   User?              @relation("InventoryCategoryCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy   User?              @relation("InventoryCategoryUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  products    InventoryProduct[]

  @@index([name])
  @@index([isActive])
  @@index([deletedAt])
  @@map("inventory_categories")
}

model InventoryProduct {
  id                String            @id @default(uuid()) @db.Uuid
  sku               String            @unique @db.VarChar(80)
  barcode           String?           @unique @db.VarChar(80)
  name              String            @db.VarChar(180)
  description       String?
  categoryId        String            @map("category_id") @db.Uuid
  unit              InventoryUnit
  costPrice         Decimal           @default(0) @map("cost_price") @db.Decimal(12, 2)
  salePrice         Decimal           @default(0) @map("sale_price") @db.Decimal(12, 2)
  minimumStock      Decimal           @default(0) @map("minimum_stock") @db.Decimal(12, 2)
  maximumStock      Decimal?          @map("maximum_stock") @db.Decimal(12, 2)
  isStockControlled Boolean           @default(true) @map("is_stock_controlled")
  isActive          Boolean           @default(true) @map("is_active")
  createdAt         DateTime          @default(now()) @map("created_at") @db.Timestamptz
  updatedAt         DateTime          @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt         DateTime?         @map("deleted_at") @db.Timestamptz
  createdById       String?           @map("created_by_id") @db.Uuid
  updatedById       String?           @map("updated_by_id") @db.Uuid
  category          InventoryCategory @relation(fields: [categoryId], references: [id])
  createdBy         User?             @relation("InventoryProductCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy         User?             @relation("InventoryProductUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  stocks            WarehouseStock[]
  movements         StockMovement[]

  @@index([categoryId])
  @@index([name])
  @@index([isActive])
  @@index([isStockControlled])
  @@index([deletedAt])
  @@map("inventory_products")
}

model Warehouse {
  id          String           @id @default(uuid()) @db.Uuid
  code        String           @unique @db.VarChar(40)
  name        String           @db.VarChar(140)
  description String?
  location    String?          @db.VarChar(180)
  isMain      Boolean          @default(false) @map("is_main")
  isActive    Boolean          @default(true) @map("is_active")
  createdAt   DateTime         @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime         @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt   DateTime?        @map("deleted_at") @db.Timestamptz
  createdById String?          @map("created_by_id") @db.Uuid
  updatedById String?          @map("updated_by_id") @db.Uuid
  createdBy   User?            @relation("WarehouseCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy   User?            @relation("WarehouseUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  stocks      WarehouseStock[]
  movements   StockMovement[]

  @@index([code])
  @@index([isMain])
  @@index([isActive])
  @@index([deletedAt])
  @@map("warehouses")
}

model WarehouseStock {
  id                String           @id @default(uuid()) @db.Uuid
  warehouseId       String           @map("warehouse_id") @db.Uuid
  productId         String           @map("product_id") @db.Uuid
  quantity          Decimal          @default(0) @db.Decimal(12, 2)
  reservedQuantity  Decimal          @default(0) @map("reserved_quantity") @db.Decimal(12, 2)
  availableQuantity Decimal          @default(0) @map("available_quantity") @db.Decimal(12, 2)
  averageCost       Decimal          @default(0) @map("average_cost") @db.Decimal(12, 2)
  updatedAt         DateTime         @updatedAt @map("updated_at") @db.Timestamptz
  warehouse         Warehouse        @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  product           InventoryProduct @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([warehouseId, productId])
  @@index([warehouseId])
  @@index([productId])
  @@map("warehouse_stocks")
}

model StockMovement {
  id             String             @id @default(uuid()) @db.Uuid
  movementNumber String             @unique @map("movement_number") @db.VarChar(30)
  productId      String             @map("product_id") @db.Uuid
  warehouseId    String             @map("warehouse_id") @db.Uuid
  movementType   StockMovementType  @map("movement_type")
  quantity       Decimal            @db.Decimal(12, 2)
  unitCost       Decimal            @default(0) @map("unit_cost") @db.Decimal(12, 2)
  totalCost      Decimal            @default(0) @map("total_cost") @db.Decimal(12, 2)
  previousStock  Decimal            @map("previous_stock") @db.Decimal(12, 2)
  newStock       Decimal            @map("new_stock") @db.Decimal(12, 2)
  referenceType  StockReferenceType @default(MANUAL) @map("reference_type")
  referenceId    String?            @map("reference_id") @db.VarChar(120)
  reason         String?            @db.VarChar(250)
  notes          String?
  createdAt      DateTime           @default(now()) @map("created_at") @db.Timestamptz
  createdById    String?            @map("created_by_id") @db.Uuid
  product        InventoryProduct   @relation(fields: [productId], references: [id])
  warehouse      Warehouse          @relation(fields: [warehouseId], references: [id])
  createdBy      User?              @relation("StockMovementCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([productId])
  @@index([warehouseId])
  @@index([movementType])
  @@index([referenceType])
  @@index([createdAt])
  @@map("stock_movements")
}

model StockMovementCounter {
  id            String   @id @default(uuid()) @db.Uuid
  prefix        String   @unique @db.VarChar(15)
  currentNumber Int      @default(0) @map("current_number")
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt     DateTime @updatedAt @map("updated_at") @db.Timestamptz

  @@map("stock_movement_counters")
}

model ServiceOrderCounter {
  id            String   @id @default(uuid()) @db.Uuid
  prefix        String   @unique @db.VarChar(15)
  currentNumber Int      @default(0) @map("current_number")
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt     DateTime @updatedAt @map("updated_at") @db.Timestamptz

  @@map("service_order_counters")
}

model Role {
  id              String           @id @default(uuid()) @db.Uuid
  name            String           @unique @db.VarChar(80)
  description     String?          @db.VarChar(255)
  isActive        Boolean          @default(true) @map("is_active")
  createdAt       DateTime         @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime         @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt       DateTime?        @map("deleted_at") @db.Timestamptz
  users           User[]
  rolePermissions RolePermission[]

  @@map("roles")
}

model Permission {
  id              String           @id @default(uuid()) @db.Uuid
  code            String           @unique @db.VarChar(120)
  name            String           @db.VarChar(120)
  description     String?          @db.VarChar(255)
  module          String           @db.VarChar(80)
  createdAt       DateTime         @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime         @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt       DateTime?        @map("deleted_at") @db.Timestamptz
  rolePermissions RolePermission[]

  @@index([module])
  @@map("permissions")
}

model RolePermission {
  id           String     @id @default(uuid()) @db.Uuid
  roleId       String     @map("role_id") @db.Uuid
  permissionId String     @map("permission_id") @db.Uuid
  createdAt    DateTime   @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime   @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt    DateTime?  @map("deleted_at") @db.Timestamptz
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@map("role_permissions")
}

model RefreshToken {
  id         String    @id @default(uuid()) @db.Uuid
  userId     String    @map("user_id") @db.Uuid
  tokenHash  String    @map("token_hash")
  expiresAt  DateTime  @map("expires_at") @db.Timestamptz
  revokedAt  DateTime? @map("revoked_at") @db.Timestamptz
  replacedBy String?   @map("replaced_by") @db.Uuid
  ipAddress  String?   @map("ip_address") @db.VarChar(80)
  userAgent  String?   @map("user_agent")
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt  DateTime  @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt  DateTime? @map("deleted_at") @db.Timestamptz
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("refresh_tokens")
}

model WorkshopSetting {
  id                    String    @id @default(uuid()) @db.Uuid
  tradeName             String    @map("trade_name") @db.VarChar(160)
  legalName             String?   @map("legal_name") @db.VarChar(160)
  taxId                 String?   @map("tax_id") @db.VarChar(40)
  address               String?   @db.VarChar(255)
  phone                 String?   @db.VarChar(30)
  email                 String?   @db.VarChar(180)
  logoUrl               String?   @map("logo_url")
  currency              String    @default("USD") @db.VarChar(10)
  timezone              String    @default("America/Guayaquil") @db.VarChar(80)
  serviceOrderPrefix    String    @default("OT") @map("service_order_prefix") @db.VarChar(15)
  quotationPrefix       String    @default("COT") @map("quotation_prefix") @db.VarChar(15)
  internalInvoicePrefix String    @default("FAC") @map("internal_invoice_prefix") @db.VarChar(15)
  createdAt             DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt             DateTime  @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt             DateTime? @map("deleted_at") @db.Timestamptz
  createdById           String?   @map("created_by_id") @db.Uuid
  updatedById           String?   @map("updated_by_id") @db.Uuid

  @@map("workshop_settings")
}

model AuditLog {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String?   @map("user_id") @db.Uuid
  action    String    @db.VarChar(80)
  module    String    @db.VarChar(80)
  entity    String?   @db.VarChar(120)
  entityId  String?   @map("entity_id") @db.VarChar(120)
  oldValues Json?     @map("old_values")
  newValues Json?     @map("new_values")
  ipAddress String?   @map("ip_address") @db.VarChar(80)
  userAgent String?   @map("user_agent")
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz
  user      User?     @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([module])
  @@index([action])
  @@index([createdAt])
  @@map("audit_logs")
}
